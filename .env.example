# ========== AMBIENTE ==========
APP_ENV=production
RENDER=false

# ========== DATABASE (CRÍTICO EM PRODUÇÃO) ==========
# Para PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ========== SECRET KEY (CRÍTICO EM PRODUÇÃO) ==========
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=troque-por-uma-chave-segura-aleatorio

# ========== SMTP (PARA EMAILS) ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app_ou_token_aqui
SMTP_FROM_EMAIL=seu_email@gmail.com

# ========== PAGAMENTOS - STRIPE ==========
STRIPE_PUBLISHABLE_KEY=pk_live_sua_chave_publica_aqui
STRIPE_SECRET_KEY=sk_live_sua_chave_secreta_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_webhook_secret_aqui

# ========== PAGAMENTOS - MERCADO PAGO ==========
MERCADOPAGO_ACCESS_TOKEN=seu-access-token
MERCADOPAGO_PUBLIC_KEY=sua-public-key
MERCADOPAGO_SANDBOX=false

# ========== PAGAMENTOS - PIX ==========
RECEIVER_CPF=seu_cpf_aqui
RECEIVER_NAME=seu_nome_completo

# ========== URLS E DOMÍNIOS ==========
APP_BASE_URL=https://seu-app.onrender.com
PRODUCTION_URL=https://simulador-gpon-hfc.me
SOCKETIO_ALLOWED_ORIGINS=https://simulador-gpon-hfc.me
TUTORIAL_PROFESSOR_URL=https://seu-tutorial-professor.com
TUTORIAL_ALUNO_URL=https://seu-tutorial-aluno.com

# ========== CONFIGURAÇÃO ==========
APP_VERSION=1.5
SESSION_LIFETIME_HOURS=12
RESET_TOKEN_EXPIRY=3600
MAX_CONTENT_LENGTH=10485760

# ========== TIMEZONE ==========
APP_TIMEZONE=America/Sao_Paulo

# ========== SOCKETIO ==========
SOCKETIO_ASYNC_MODE=eventlet

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========== PORT ==========
PORT=5000
FLASK_DEBUG=false

# ========== ADMIN ==========
ADMIN_EMAILS=jonatansilvaromao@gmail.com
